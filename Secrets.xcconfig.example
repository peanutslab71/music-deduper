// DEVELOPER-ONLY key fallback.
//
// Normal users don't touch this file — they enter their keys in the app under
// Music Librarian > Settings (stored in the Keychain). See docs/API-KEYS.md.
//
// Keys set here are used ONLY as a fallback when the Keychain is empty, which is
// handy while developing. They get baked into the built app's Info.plist, so:
//
//   *** LEAVE BOTH BLANK IN ANY BUILD YOU DISTRIBUTE ***
//   (a real token here would be published inside the shipped app).
//
// To use: copy this file to Secrets.xcconfig and fill in as needed.

// Free AcoustID key — https://acoustid.org/new-application
ACOUSTID_API_KEY =

// Optional free Discogs personal token (raises credit lookups 25->60/min).
// Generate at https://www.discogs.com/settings/developers
DISCOGS_TOKEN =
